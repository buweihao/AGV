<UserControl x:Class="BasicRegionNavigation.Views.ViewA"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:BasicRegionNavigation.Views"
             xmlns:core ="clr-namespace:Core"
             xmlns:prism="http://prismlibrary.com/"             
             xmlns:ctrls="clr-namespace:BasicRegionNavigation.Controls" 
             xmlns:con="clr-namespace:BasicRegionNavigation.Controls" 
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SectionHeaderStyle" TargetType="ContentControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border CornerRadius="6,6,0,0" Background="#2e3a44">
                                <TextBlock Text="{TemplateBinding Content}" 
                               Margin="0,5,0,6"
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Padding="4"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:IntToBrushConverter x:Key="IntToBrushConverter"/>

        </ResourceDictionary>
    </UserControl.Resources>
    <!-- 主体内容 -->
    <Grid Margin="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="10" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                <TextBlock Text="随机调度:" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
                <Button Content="发车订单" Command="{Binding DispatchTaskCommand}" Width="100" Height="30" FontSize="16" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding RobotPositionText}" VerticalAlignment="Center" FontSize="16" Foreground="Blue"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="暂停" Command="{Binding PauseRobotCommand}" Width="80" Height="30" FontSize="16" Margin="0,0,10,0"/>
                <Button Content="继续" Command="{Binding ResumeRobotCommand}" Width="80" Height="30" FontSize="16" Margin="0,0,10,0"/>
                <Button Content="取消" Command="{Binding CancelRobotCommand}" Width="80" Height="30" FontSize="16" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding Robot1StateText}" VerticalAlignment="Center" FontSize="16" Foreground="Blue" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding Robot2StateText}" VerticalAlignment="Center" FontSize="16" Foreground="Red" FontWeight="Bold"/>
            </StackPanel>

            <!-- 新增的 Zone 管制测试控制组 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                <TextBlock Text="死锁预防测试:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#333"/>
                <Button Content="[1] 测试旁路管制" ToolTip="模拟 AGV-1 与 AGV-2 在 Zone_A 管制区边缘的寻路与区域锁释放逻辑" Command="{Binding TestCorridorCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#E1F5FE" BorderBrush="#42A5F5"/>
                <Button Content="[2] 测试路口拦截" ToolTip="模拟南北(1->2)与东西(4->3)并发任务，验证中心节点(0)的交通拦截" Command="{Binding TestIntersectionCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#E8F5E9" BorderBrush="#66BB6A"/>
                <Button Content="[3] 测试中心死锁" ToolTip="强制两车同时抢占中心 Node 0，测试死锁规避或锁竞争逻辑" Command="{Binding TestDeadlockCommand}" Height="30" Padding="15,0" FontSize="14" Background="#FFEBEE" BorderBrush="#EF5350" Foreground="#D32F2F"/>
            </StackPanel>
        </StackPanel>

        <!-- 机器人模拟区域及微型路网 -->
        <Canvas Grid.Row="1" Grid.Column="0" Background="#F0F0F0" Margin="10" ClipToBounds="True">
            
            <!-- 极限测试地图背景装饰 -->
            <Rectangle Canvas.Left="100" Canvas.Top="100" Width="400" Height="40" Fill="#2042A5F5" Stroke="#4042A5F5" StrokeThickness="1" StrokeDashArray="4,4" RadiusX="10" RadiusY="10" Panel.ZIndex="-1"/>
            <TextBlock Canvas.Left="260" Canvas.Top="75" Text="Zone_A 管制区" Foreground="#42A5F5" FontWeight="Bold" FontSize="12" Panel.ZIndex="-1"/>

            <!-- 绘制地图连线 (硬编码以符合 Sprint 1 拓扑) -->
            <Canvas Panel.ZIndex="0">
                <Line X1="300" Y1="300" X2="300" Y2="100" Stroke="#CCC" StrokeThickness="4"/> <!-- 0-1 -->
                <Line X1="300" Y1="300" X2="300" Y2="500" Stroke="#CCC" StrokeThickness="4"/> <!-- 0-2 -->
                <Line X1="300" Y1="300" X2="500" Y2="300" Stroke="#CCC" StrokeThickness="4"/> <!-- 0-3 -->
                <Line X1="300" Y1="300" X2="100" Y2="300" Stroke="#CCC" StrokeThickness="4"/> <!-- 0-4 -->
                <Line X1="100" Y1="300" X2="100" Y2="100" Stroke="#CCC" StrokeThickness="4"/> <!-- 4-5 -->
                <Line X1="100" Y1="100" X2="500" Y2="100" Stroke="#CCC" StrokeThickness="4"/> <!-- 5-6 -->
                <Line X1="500" Y1="100" X2="500" Y2="300" Stroke="#CCC" StrokeThickness="4"/> <!-- 6-3 -->
                <Line X1="300" Y1="500" X2="500" Y2="500" Stroke="#CCC" StrokeThickness="4"/> <!-- 2-7 -->
            </Canvas>

            <!-- 渲染路网节点 -->
            <ItemsControl ItemsSource="{Binding MapNodes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="-15,-15,0,0" Width="80" Height="40" ToolTip="{Binding ZoneName}">
                            <Ellipse x:Name="NodeElement" Width="30" Height="30" Fill="#BDC3C7" Stroke="#95A5A6" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding Id}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,5,0,0" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding Id, StringFormat='节点 {0}'}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="35,5,0,0" FontWeight="Bold" Foreground="#2C3E50"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- 特殊节点着色 -->
                            <DataTrigger Binding="{Binding NodeType}" Value="Charging">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#2ECC71"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#27AE60"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ZoneName}" Value="Zone_A">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#3498DB"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#2980B9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Id}" Value="0">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#E74C3C"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#C0392B"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 代表 AGV-1 的图形 -->
            <Border Width="30" Height="30" Background="Blue" CornerRadius="4" 
                    Canvas.Left="{Binding Robot1X}" Canvas.Top="{Binding Robot1Y}"
                    Margin="-15,-15,0,0">
                <TextBlock Text="AGV1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="11"/>
            </Border>

            <!-- 代表 AGV-2 的图形 -->
            <Border Width="30" Height="30" Background="Red" CornerRadius="4" 
                    Canvas.Left="{Binding Robot2X}" Canvas.Top="{Binding Robot2Y}"
                    Margin="-15,-15,0,0">
                <TextBlock Text="AGV2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="11"/>
            </Border>
        </Canvas>

        <!-- 右侧任务列表栏 -->
        <Border Grid.Row="1" Grid.Column="1" Background="White" Margin="0,10,10,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#2e3a44" CornerRadius="8,8,0,0" Padding="15,10">
                    <TextBlock Text="🎯 实时调度任务栏" Foreground="White" FontSize="16" FontWeight="Bold"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActiveTasks}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="12" Background="#F8F9FA" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderId}" FontWeight="Bold" Foreground="#333" FontSize="14" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding AssignedRobotId}" Foreground="#007BFF" FontWeight="Bold"/>
                                            <TextBlock Text=" ➔ " Foreground="#888"/>
                                            <TextBlock Text="{Binding TargetNodeId, StringFormat='节点 {0}'}" Foreground="#555" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#2E8B57" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 错误提示遮罩 -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding RobotErrorVisibility}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" Padding="30" CornerRadius="10" BorderBrush="Red" BorderThickness="4">
                <StackPanel>
                    <TextBlock Text="⚠ 故障警告" FontSize="24" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding RobotErrorText}" FontSize="18" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="重置机器人" Command="{Binding ResetRobotCommand}" Width="150" Height="40" FontSize="16" Background="Red" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
