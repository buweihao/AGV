<UserControl x:Class="BasicRegionNavigation.Views.ViewA"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:BasicRegionNavigation.Views"
             xmlns:core ="clr-namespace:Core"
             xmlns:prism="http://prismlibrary.com/"             
             xmlns:ctrls="clr-namespace:BasicRegionNavigation.Controls" 
             xmlns:con="clr-namespace:BasicRegionNavigation.Controls" 
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <Style x:Key="SectionHeaderStyle" TargetType="ContentControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border CornerRadius="6,6,0,0" Background="#2e3a44">
                                <TextBlock Text="{TemplateBinding Content}" 
                               Margin="0,5,0,6"
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Padding="4"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:IntToBrushConverter x:Key="IntToBrushConverter"/>

        </ResourceDictionary>
    </UserControl.Resources>
    <!-- 主体内容 -->
    <Grid Margin="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Vertical" Margin="10" HorizontalAlignment="Center">


            <!-- 动态添加/删除车辆 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                <TextBlock Text="车辆动态管理:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#333"/>
                <TextBlock Text="节点ID:" VerticalAlignment="Center" FontSize="14" Margin="0,0,5,0"/>
                <TextBox Text="{Binding NewRobotNodeId}" Width="50" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="➕ 放置车辆" Command="{Binding AddRobotCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#E8F5E9" BorderBrush="#81C784"/>
                <Button Content="🗑️ 清除所有车辆" Command="{Binding ClearRobotsCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#FFEBEE" BorderBrush="#E57373"/>
            </StackPanel>

            <!-- 自定义配置任务流 (Sprint 2.1) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                <TextBlock Text="任务模版派单:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#0277BD"/>
                <ComboBox ItemsSource="{Binding TaskTemplates}" 
                          SelectedItem="{Binding SelectedTaskTemplate}"
                          DisplayMemberPath="TemplateName"
                          Width="220" Height="32" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#0277BD"/>
                <Button Content="🚀 派发定制任务" 
                        ToolTip="按照选中的 JSON 配置模版下发完整动作任务流"
                        Command="{Binding DispatchSelectedTemplateCommand}" 
                        Height="32" Padding="20,0" FontSize="14" FontWeight="Bold" Margin="15,0,0,0" 
                        Background="#E3F2FD" BorderBrush="#0277BD" BorderThickness="2" Foreground="#01579B"/>

                <!-- [新增] 自动化任务生成器 -->
                <TextBlock Text="⚡ 自动化生成:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="35,0,10,0" Foreground="#2E7D32"/>
                <hc:ComboBox SelectedValuePath="Tag" 
                             SelectedValue="{Binding AutoTaskInterval}"
                             Width="110" Height="32" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#2E7D32">
                    <ComboBoxItem Content="压测 (1s)" Tag="1000"/>
                    <ComboBoxItem Content="极速 (2s)" Tag="2000"/>
                    <ComboBoxItem Content="快速 (5s)" Tag="5000"/>
                    <ComboBoxItem Content="中速 (15s)" Tag="15000" IsSelected="True"/>
                    <ComboBoxItem Content="慢速 (30s)" Tag="30000"/>
                </hc:ComboBox>

                <Button Command="{Binding ToggleAutoTaskGeneratorCommand}" 
                        Height="32" Padding="20,0" Margin="15,0,0,0" FontSize="14" FontWeight="Bold">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="▶ 开启任务生成"/>
                            <Setter Property="Background" Value="#E8F5E9"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Setter Property="BorderBrush" Value="#2E7D32"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAutoTaskRunning}" Value="True">
                                    <Setter Property="Content" Value="⏹ 停止生成器"/>
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                    <Setter Property="BorderBrush" Value="#EF5350"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- [新增] 全局属性控制面板 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="⚡ 小车移速:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,10,0" Foreground="#E65100"/>
                <Slider Value="{Binding RobotGlobalSpeed}" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Width="180" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding RobotGlobalSpeed, StringFormat={}{0} px/tick}" VerticalAlignment="Center" FontSize="14" Foreground="#E65100" FontWeight="Bold" Width="80"/>

                <TextBlock Text="🔌 充电时间:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="35,0,10,0" Foreground="#2E7D32"/>
                <Slider Value="{Binding RobotChargeTime}" Minimum="500" Maximum="10000" TickFrequency="500" IsSnapToTickEnabled="True" Width="180" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding RobotChargeTime, StringFormat={}{0} ms}" VerticalAlignment="Center" FontSize="14" Foreground="#2E7D32" FontWeight="Bold" Width="80" ToolTip="模拟充满电所需的时间(ms)"/>
            </StackPanel>
        </StackPanel>

        <!-- Web 容器，加载 agv_html-main 项目 -->
        <wv2:WebView2 x:Name="ReactAppWebView" 
                      Grid.Row="1" Grid.Column="0"
                      Source="http://localhost:3000" 
                      Visibility="Visible"
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      Margin="10"/>

        <!-- 只有在非 Web 模式下才显示的旧版地图（此处隐藏） -->
        <ScrollViewer x:Name="MapScrollViewer" Grid.Row="1" Grid.Column="0" Margin="10" 
                      Visibility="Collapsed"
                      Background="#F0F0F0"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel"
                      PreviewMouseDown="MapScrollViewer_PreviewMouseDown"
                      PreviewMouseMove="MapScrollViewer_PreviewMouseMove"
                      PreviewMouseUp="MapScrollViewer_PreviewMouseUp">
            <Canvas x:Name="MapCanvas" Width="2500" Height="1800" Background="Transparent">
                <Canvas.LayoutTransform>
                    <ScaleTransform x:Name="MapScaleTransform" ScaleX="1.0" ScaleY="1.0" />
                </Canvas.LayoutTransform>

                <!-- 动态路网连线：支持双向线与带方向箭头的单向线 -->
            <ItemsControl ItemsSource="{Binding MapEdges}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Canvas>
                            <!-- 基础路网线段 -->
                            <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" 
                                  Stroke="LightGray" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            
                            <!-- 单向箭头指示器 -->
                            <Polygon Points="-6,-6 10,0 -6,6" Fill="#95A5A6" 
                                     Visibility="{Binding IsOneWay, Converter={StaticResource BoolToVis}}"
                                     Canvas.Left="{Binding CenterX}" Canvas.Top="{Binding CenterY}">
                                 <Polygon.RenderTransform>
                                     <RotateTransform Angle="{Binding Angle}" />
                                 </Polygon.RenderTransform>
                             </Polygon>
                             </Canvas>
                     </DataTemplate>
                 </ItemsControl.ItemTemplate>
             </ItemsControl>

            <!-- 渲染路网节点 -->
            <ItemsControl ItemsSource="{Binding MapNodes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="-15,-15,0,0" Width="80" Height="40" ToolTip="{Binding ZoneName}">
                            <Ellipse x:Name="NodeElement" Width="30" Height="30" Fill="#BDC3C7" Stroke="#95A5A6" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding Id}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,5,0,0" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding DisplayLabel}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="35,5,0,0" FontWeight="Bold" Foreground="#2C3E50"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- 特殊节点着色 -->
                            <DataTrigger Binding="{Binding NodeType}" Value="Charging">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#2ECC71"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#27AE60"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ZoneName}" Value="Zone_A">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#3498DB"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#2980B9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ZoneName}" Value="Zone_Center">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#E67E22"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#D35400"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Id}" Value="0">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#E74C3C"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#C0392B"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding RobotList}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding CurrentX}"/>
                        <Setter Property="Canvas.Top" Value="{Binding CurrentY}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="30" Height="30" Background="#1976D2" CornerRadius="4" Margin="-15,-15,0,0">
                            <TextBlock Text="{Binding Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="11"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Canvas>
        </ScrollViewer>

        <!-- 右侧任务列表栏 -->
        <Border Grid.Row="1" Grid.Column="1" Background="White" Margin="0,10,10,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 任务列表 -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#2e3a44" CornerRadius="8,8,0,0" Padding="15,10">
                        <TextBlock Text="🎯 实时调度任务栏" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActiveTasks}" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="12" Background="#F8F9FA" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderId}" FontWeight="Bold" Foreground="#333" FontSize="14" Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="{Binding AssignedRobotId}" Foreground="#007BFF" FontWeight="Bold"/>
                                                <TextBlock Text=" ➔ " Foreground="#888"/>
                                                <TextBlock Text="{Binding StageDescription}" Foreground="#555" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding StatusDisplayText}" FontSize="12" Foreground="#2E8B57" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- 分割线 -->
                <Rectangle Grid.Row="1" Height="2" Fill="#E0E0E0" Margin="10,0"/>

                <!-- 锁状态监控 -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#455A64" Padding="15,10">
                        <TextBlock Text="🔒 交通管制锁状态" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActiveLocks}" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,5" Padding="8" Background="#FFF9C4" CornerRadius="4" BorderBrush="#FBC02D" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ZoneName}" FontWeight="Bold" Foreground="#D32F2F"/>
                                            <TextBlock Grid.Column="1" Text=" 🔑 " Foreground="#888"/>
                                            <TextBlock Grid.Column="2" Text="{Binding RobotId}" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- AGV 实时状态监控边栏 (新布局：右侧垂直侧栏) -->
        <Border Grid.Row="1" Grid.Column="2" Margin="0,10,10,10" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 侧栏标题 -->
                <Border Background="#1976D2" CornerRadius="8,8,0,0" Padding="15,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋 AGV 实时追踪" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding RobotList.Count, StringFormat='({0})'}" Foreground="#BBDEFB" FontSize="14" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 垂直滚动的 AGV 详情列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RobotList}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="12" Background="#F8F9FA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Border.ToolTip>
                                        <ToolTip Background="Transparent" BorderThickness="0" Padding="0">
                                            <Border Background="#2E3A44" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#455A64">
                                                <StackPanel Width="220">
                                                    <TextBlock Text="📊 实时运行效益分析" Foreground="#BBDEFB" FontWeight="Bold" Margin="0,0,0,10"/>
                                                    
                                                    <Grid Margin="0,0,0,5">
                                                        <TextBlock Text="任务吞吐:" Foreground="#AAA" FontSize="11"/>
                                                        <TextBlock Text="{Binding TasksPerMinute, StringFormat='{}{0:F1} 单/分'}" Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,5">
                                                        <TextBlock Text="路程负荷:" Foreground="#AAA" FontSize="11"/>
                                                        <TextBlock Text="{Binding DistancePerMinute, StringFormat='{}{0:F1} m/分'}" Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <TextBlock Text="电能效率:" Foreground="#AAA" FontSize="11"/>
                                                        <TextBlock Text="{Binding BatteryPerMinute, StringFormat='{}-{0:F1} %/分'}" Foreground="#FFA726" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                    </Grid>
                                                    
                                                    <Rectangle Height="1" Fill="#556" Margin="0,0,0,10"/>
                                                    
                                                    <TextBlock Text="🚧 反馈统计" Foreground="#BBDEFB" FontWeight="Bold" Margin="0,0,0,5"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding MaxStopSec, StringFormat='{}最长阻塞: {0:F1} 秒'}" Foreground="#EF5350" FontSize="11" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding MaxStopReasonText, StringFormat='{}原因: {0}'}" Foreground="#CCC" FontSize="10" TextWrapping="Wrap" Opacity="0.8"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 第一行: ID 与 状态标签 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Id}" FontWeight="Bold" Foreground="#1976D2" FontSize="16"/>
                                            <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CurrentStateText}" Foreground="#1976D2" FontWeight="ExtraBold" FontSize="11"/>
                                            </Border>
                                        </Grid>

                                        <!-- 第二行: 电量图标与位置 -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="🔋" Margin="0,0,5,0" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding BatteryLevel, StringFormat={}{0:F0}%}" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                            
                                            <TextBlock Text="📍" Margin="0,0,5,0" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CurrentNode}" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 第三行: 详细任务描述 -->
                                        <Border Grid.Row="2" Background="#FFFFFF" Padding="8,5" CornerRadius="4" BorderBrush="#F0F0F0" BorderThickness="1">
                                            <TextBlock Text="{Binding CurrentTaskDesc}" FontStyle="Italic" Foreground="#666" FontSize="12" TextWrapping="Wrap"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- 底部统计 -->
                <Border Grid.Row="2" Background="#F5F5F5" Padding="10,5" CornerRadius="0,0,8,8">
                    <TextBlock Text="数据自动刷新中..." FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- 错误提示遮罩 -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="3" Background="#80000000" Visibility="{Binding RobotErrorVisibility}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" Padding="30" CornerRadius="10" BorderBrush="Red" BorderThickness="4">
                <StackPanel>
                    <TextBlock Text="⚠ 故障警告" FontSize="24" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding RobotErrorText}" FontSize="18" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="重置机器人" Command="{Binding ResetRobotCommand}" Width="150" Height="40" FontSize="16" Background="Red" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
