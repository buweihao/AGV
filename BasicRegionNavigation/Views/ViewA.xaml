<UserControl x:Class="BasicRegionNavigation.Views.ViewA"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:BasicRegionNavigation.Views"
             xmlns:core ="clr-namespace:Core"
             xmlns:prism="http://prismlibrary.com/"             
             xmlns:ctrls="clr-namespace:BasicRegionNavigation.Controls" 
             xmlns:con="clr-namespace:BasicRegionNavigation.Controls" 
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <Style x:Key="SectionHeaderStyle" TargetType="ContentControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border CornerRadius="6,6,0,0" Background="#2e3a44">
                                <TextBlock Text="{TemplateBinding Content}" 
                               Margin="0,5,0,6"
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Padding="4"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:IntToBrushConverter x:Key="IntToBrushConverter"/>

        </ResourceDictionary>
    </UserControl.Resources>
    <!-- 主体内容 -->
    <Grid Margin="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="10" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                <TextBlock Text="随机调度:" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
                <Button Content="发车订单" Command="{Binding DispatchCustomSequenceTaskCommand}" Width="100" Height="30" FontSize="16" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding RobotPositionText}" VerticalAlignment="Center" FontSize="16" Foreground="Blue"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="暂停" Command="{Binding PauseRobotCommand}" Width="80" Height="30" FontSize="16" Margin="0,0,10,0"/>
                <Button Content="继续" Command="{Binding ResumeRobotCommand}" Width="80" Height="30" FontSize="16" Margin="0,0,10,0"/>
                <Button Content="取消" Command="{Binding CancelRobotCommand}" Width="80" Height="30" FontSize="16" Margin="0,0,20,0"/>
            </StackPanel>

            <!-- 新增的 Zone 管制测试控制组 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                <TextBlock Text="死锁预防测试:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#333"/>
                <Button Content="[0] 管制区排队测试" ToolTip="核心测试：R2 从 Zone_A 出去的同时，R1 在入口处排队等待" Command="{Binding RunTestOne_ZoneQueueingCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#FFF9C4" BorderBrush="#FBC02D"/>
                <Button Content="[1] 测试旁路管制" ToolTip="模拟 AGV-1 与 AGV-2 在 Zone_A 管制区边缘的寻路与区域锁释放逻辑" Command="{Binding TestCorridorCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#E1F5FE" BorderBrush="#42A5F5"/>
                <Button Content="[2] 测试路口拦截" ToolTip="模拟南北(1->2)与东西(4->3)并发任务，验证中心节点(0)的交通拦截" Command="{Binding TestIntersectionCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#E8F5E9" BorderBrush="#66BB6A"/>
                <Button Content="[3] 测试中心死锁" ToolTip="强制两车同时抢占中心 Node 0，测试死锁规避或锁竞争逻辑" Command="{Binding TestDeadlockCommand}" Height="30" Padding="15,0" FontSize="14" Background="#FFEBEE" BorderBrush="#EF5350" Foreground="#D32F2F"/>
                <Button Content="[4] 就近分配测试" ToolTip="核心测试：3台车不同距离，验证调度引擎是否精确挑选最近的R3" Command="{Binding RunTestTwo_NearestAllocationCommand}" Height="30" Padding="15,0" FontSize="14" Margin="10,0,0,0" Background="#E0F7FA" BorderBrush="#00ACC1"/>
            </StackPanel>
            
            <!-- 生产节拍模拟 (冲刺2) 控制组 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,10">
                <TextBlock Text="生产进度模拟 (Sprint 2):" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#6A1B9A"/>
                <Button Content="[初始化] 3台车待命" ToolTip="重置沙盘并放置 3 台 AGV 处于三向待命区" Command="{Binding InitThreeRobotsCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#F3E5F5" BorderBrush="#CE93D8"/>
                <Button Content="[单次呼叫] 1号机床需要上料" ToolTip="模拟一号机床发起临时上料请求：原料区->1号机床->停车区" Command="{Binding CallMachineOneMaterialCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#FFF3E0" BorderBrush="#FFB74D"/>
                <Button Content="[连续模拟] 开启/关闭工厂自动接单" ToolTip="循环下发随机生产任务，模拟工厂真实运行节拍" Command="{Binding ToggleContinuousSimulationCommand}" Height="30" Padding="15,0" FontSize="14" Background="#E8F5E9" BorderBrush="#81C784"/>
            </StackPanel>

            <!-- 动态添加/删除车辆 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                <TextBlock Text="车辆动态管理:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#333"/>
                <TextBlock Text="节点ID:" VerticalAlignment="Center" FontSize="14" Margin="0,0,5,0"/>
                <TextBox Text="{Binding NewRobotNodeId}" Width="50" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="➕ 放置车辆" Command="{Binding AddRobotCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#E8F5E9" BorderBrush="#81C784"/>
                <Button Content="🗑️ 清除所有车辆" Command="{Binding ClearRobotsCommand}" Height="30" Padding="15,0" FontSize="14" Margin="0,0,10,0" Background="#FFEBEE" BorderBrush="#E57373"/>
            </StackPanel>

            <!-- 自定义配置任务流 (Sprint 2.1) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                <TextBlock Text="任务模版派单:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,15,0" Foreground="#0277BD"/>
                <ComboBox ItemsSource="{Binding TaskTemplates}" 
                          SelectedItem="{Binding SelectedTaskTemplate}"
                          DisplayMemberPath="TemplateName"
                          Width="220" Height="32" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#0277BD"/>
                <Button Content="🚀 派发定制任务" 
                        ToolTip="按照选中的 JSON 配置模版下发完整动作任务流"
                        Command="{Binding DispatchSelectedTemplateCommand}" 
                        Height="32" Padding="20,0" FontSize="14" FontWeight="Bold" Margin="15,0,0,0" 
                        Background="#E3F2FD" BorderBrush="#0277BD" BorderThickness="2" Foreground="#01579B"/>
            </StackPanel>
        </StackPanel>

        <!-- 机器人模拟区域及微型路网 -->
        <Canvas Grid.Row="1" Grid.Column="0" Background="#F0F0F0" Margin="10" ClipToBounds="True">
            
            <!-- 极限测试地图背景装饰 -->
            <Rectangle Canvas.Left="100" Canvas.Top="100" Width="400" Height="40" Fill="#2042A5F5" Stroke="#4042A5F5" StrokeThickness="1" StrokeDashArray="4,4" RadiusX="10" RadiusY="10" Panel.ZIndex="-1"/>
            <TextBlock Canvas.Left="260" Canvas.Top="75" Text="Zone_A 管制区" Foreground="#42A5F5" FontWeight="Bold" FontSize="12" Panel.ZIndex="-1"/>

            <!-- Zone_Center 中心区背景装饰 (补丁:覆盖 11-14 + 0) -->
            <Rectangle Canvas.Left="215" Canvas.Top="215" Width="170" Height="170" Fill="#25E67E22" Stroke="#60E67E22" StrokeThickness="1.5" StrokeDashArray="6,3" RadiusX="12" RadiusY="12" Panel.ZIndex="-1"/>
            <TextBlock Canvas.Left="255" Canvas.Top="195" Text="Zone_Center" Foreground="#E67E22" FontWeight="Bold" FontSize="12" Panel.ZIndex="-1"/>

            <!-- 动态路网连线：支持双向线与带方向箭头的单向线 -->
            <ItemsControl ItemsSource="{Binding MapEdges}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Canvas>
                            <!-- 基础路网线段 -->
                            <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" 
                                  Stroke="LightGray" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            
                            <!-- 单向箭头指示器 -->
                            <Polygon Points="-6,-6 10,0 -6,6" Fill="#95A5A6" 
                                     Visibility="{Binding IsOneWay, Converter={StaticResource BoolToVis}}"
                                     Canvas.Left="{Binding CenterX}" Canvas.Top="{Binding CenterY}">
                                <Polygon.RenderTransform>
                                    <RotateTransform Angle="{Binding Angle}" />
                                </Polygon.RenderTransform>
                            </Polygon>
                            </Canvas>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 渲染路网节点 -->
            <ItemsControl ItemsSource="{Binding MapNodes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="-15,-15,0,0" Width="80" Height="40" ToolTip="{Binding ZoneName}">
                            <Ellipse x:Name="NodeElement" Width="30" Height="30" Fill="#BDC3C7" Stroke="#95A5A6" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding Id}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,5,0,0" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding Id, StringFormat='节点 {0}'}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="35,5,0,0" FontWeight="Bold" Foreground="#2C3E50"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- 特殊节点着色 -->
                            <DataTrigger Binding="{Binding NodeType}" Value="Charging">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#2ECC71"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#27AE60"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ZoneName}" Value="Zone_A">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#3498DB"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#2980B9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ZoneName}" Value="Zone_Center">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#E67E22"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#D35400"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Id}" Value="0">
                                <Setter TargetName="NodeElement" Property="Fill" Value="#E74C3C"/>
                                <Setter TargetName="NodeElement" Property="Stroke" Value="#C0392B"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding RobotList}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding CurrentX}"/>
                        <Setter Property="Canvas.Top" Value="{Binding CurrentY}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="30" Height="30" Background="#1976D2" CornerRadius="4" Margin="-15,-15,0,0">
                            <TextBlock Text="{Binding Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="11"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>

        <!-- 右侧任务列表栏 -->
        <Border Grid.Row="1" Grid.Column="1" Background="White" Margin="0,10,10,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#2e3a44" CornerRadius="8,8,0,0" Padding="15,10">
                    <TextBlock Text="🎯 实时调度任务栏" Foreground="White" FontSize="16" FontWeight="Bold"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActiveTasks}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="12" Background="#F8F9FA" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderId}" FontWeight="Bold" Foreground="#333" FontSize="14" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding AssignedRobotId}" Foreground="#007BFF" FontWeight="Bold"/>
                                            <TextBlock Text=" ➔ " Foreground="#888"/>
                                            <TextBlock Text="{Binding TargetNodeId, StringFormat='节点 {0}'}" Foreground="#555" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding StatusDisplayText}" FontSize="12" Foreground="#2E8B57" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- AGV 实时状态监控列表 (Row 2) -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="10,0,10,10" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#f8f9fa" CornerRadius="8,8,0,0" Padding="10,5">
                    <TextBlock Text="📋 AGV 实时状态监控" FontWeight="Bold" Foreground="#333"/>
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RobotList}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" Background="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="小车编号" Binding="{Binding Id}" Width="100"/>
                        <DataGridTemplateColumn Header="运行状态" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E3F2FD" CornerRadius="4" Padding="5,2" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding CurrentStateText}" Foreground="#1976D2" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="当前电量" Binding="{Binding BatteryLevel, StringFormat={}{0:F1}%}" Width="100"/>
                        <DataGridTextColumn Header="所在节点" Binding="{Binding CurrentNode}" Width="100"/>
                        <DataGridTextColumn Header="任务描述" Binding="{Binding CurrentTaskDesc}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 错误提示遮罩 -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding RobotErrorVisibility}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" Padding="30" CornerRadius="10" BorderBrush="Red" BorderThickness="4">
                <StackPanel>
                    <TextBlock Text="⚠ 故障警告" FontSize="24" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding RobotErrorText}" FontSize="18" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="重置机器人" Command="{Binding ResetRobotCommand}" Width="150" Height="40" FontSize="16" Background="Red" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
